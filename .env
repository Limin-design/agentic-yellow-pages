############################################  
# Azure OpenAI  
############################################  
AZURE_OPENAI_API_KEY=your_azure_openai_key  
AZURE_OPENAI_ENDPOINT=https://your-openai-resource.openai.azure.com  
AZURE_OPENAI_API_VERSION=2024-02-15-preview  
  
# Deployments  
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o  
AZURE_OPENAI_FALLBACK_DEPLOYMENT=gpt-4o-mini  
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small  
  
############################################  
# Azure AI Search  
############################################  
AZURE_SEARCH_ENDPOINT=https://teacher.search.windows.net  
AZURE_SEARCH_ADMIN_KEY=your_search_admin_key  
AZURE_SEARCH_INDEX_NAME=idx-docs-rag-prod  
  
############################################  
# Safety / Cost Controls (STRICT)  
############################################  
OPENAI_ENABLED=true  
  
# Per request  
OPENAI_MAX_INPUT_CHARS=4000  
OPENAI_MAX_OUTPUT_TOKENS=300  
OPENAI_TEMPERATURE=0.3  
OPENAI_TIMEOUT_MS=20000  
OPENAI_MAX_RETRIES=2  
  
# Rate limiting  
RATE_LIMIT_PER_USER_PER_DAY=30  
RATE_LIMIT_GLOBAL_PER_DAY=500  
RATE_LIMIT_PER_MINUTE=20  
  
# RAG controls  
RAG_TOP_K=3  
RAG_MAX_CONTEXT_CHARS=6000  
RAG_CHUNK_SIZE=800  
RAG_CHUNK_OVERLAP=100  
  
# Budget guardrails (app-side soft stops)  
MONTHLY_BUDGET_EUR=25  
BUDGET_ALERT_50_ENABLED=true  
BUDGET_ALERT_80_ENABLED=true  
BUDGET_HARD_STOP_ENABLED=true  
BUDGET_HARD_STOP_THRESHOLD_EUR=25  
  
############################################  
# Optional logging  
############################################  
LOG_LEVEL=info  
LOG_TOKEN_USAGE=true  
